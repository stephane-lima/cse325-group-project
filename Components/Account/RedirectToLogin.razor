@inject NavigationManager Navigation

@*
    Helper component: redirects unauthenticated users to the login page,
    preserving where they were headed via a returnUrl query parameter.
*@

@code {
    protected override void OnInitialized()
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        Navigation.NavigateTo($"login?returnUrl=/{Uri.EscapeDataString(returnUrl)}", forceLoad: true);
    }
}
