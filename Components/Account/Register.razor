@*
    Register.razor
    Purpose: Provides a user registration form for creating an account.
    Notes: Uses data annotations for validation and calls the injected `IAccountService`.
*@
@page "/register"
@page "/Account/Register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using BudgetAndExpenseTracker.Services
@using BudgetAndExpenseTracker.Data
@using BudgetAndExpenseTracker.Models
@inject IAccountService AccountService
@inject NavigationManager Navigation

<PageTitle>Create account</PageTitle>

<section class="auth-page" style="display: flex; justify-content: center; align-items: center; min-height: 60vh; background-color: #ffffff; padding: 2rem 1rem;">
    <div class="auth-card" style="background: #f9fafb; border: 1px solid #e5e7eb; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.02); width: 100%; max-width: 420px;">
        <header class="auth-card__header" style="margin-bottom: 2rem; text-align: center;">
            <h1 class="auth-card__title" style="font-size: 1.75rem; font-weight: 800; color: #111827; margin: 0 0 0.5rem 0;">Create account</h1>
            <p class="auth-card__subtitle" style="font-size: 0.9rem; color: #6b7280; margin: 0;">Start tracking your budget in minutes.</p>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="auth-alert" role="alert" style="background-color: #fee2e2; color: #dc2626; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1.5rem; text-align: center;">
                @_errorMessage
            </div>
        }

        @* <Alert Message="@_errorMessage" Type="error" Visible="@(!string.IsNullOrEmpty(_errorMessage))" OnClose="@(()=> _errorMessage = null)" /> *@

        <EditForm Model="Input" method="post" OnValidSubmit="RegisterAsync" FormName="registerForm" novalidate>
            <DataAnnotationsValidator />

            <div class="auth-field" style="margin-bottom: 1.25rem;">
                <label for="name" class="form-label">Display name</label>
                <InputText id="name" class="form-control" @bind-Value="Input!.DisplayName" autocomplete="name" placeholder="Jane Doe" />
                <ValidationMessage For="() => Input.DisplayName" class="validation-message" />
            </div>

            <div class="auth-field" style="margin-bottom: 1.25rem;">
                <label for="email" class="form-label">Email</label>
                <InputText id="email" class="form-control" @bind-Value="Input!.Email" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                <ValidationMessage For="() => Input.Email" class="validation-message" />
            </div>

            <div class="auth-field" style="margin-bottom: 1.25rem;">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="Input!.Password" autocomplete="new-password" aria-required="true" placeholder="At least 6 characters" />
                <ValidationMessage For="() => Input.Password" class="validation-message" />
            </div>

            <div class="auth-field" style="margin-bottom: 1.5rem;">
                <label for="confirm" class="form-label">Confirm password</label>
                <InputText id="confirm" type="password" class="form-control" @bind-Value="Input!.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="Re-enter your password" />
                <ValidationMessage For="() => Input.ConfirmPassword" class="validation-message" />
            </div>

            <button type="submit" class="btn-submit" aria-label="Create Account">Create account</button>
        </EditForm>

        <p class="auth-switch" style="text-align: center; font-size: 0.85rem; color: #4b5563; margin-top: 1.5rem; margin-bottom: 0;">
            Already have an account? <a href="Account/Login" style="color: #065f46; font-weight: 700; text-decoration: none;">Log in</a>
        </p>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private RegisterInput? Input { get; set; }

    private string? _errorMessage;

    /// <summary>
    /// Initialize the registration component and ensure the bound input model is not null.
    /// </summary>
    protected override void OnInitialized()
    {
        Input ??= new();
    }
    /// <summary>
    /// Handles the registration form submission. Calls into <see cref="IAccountService"/>
    /// to create the new user, then signs the user in using cookie authentication.
    /// </summary>
    private async Task RegisterAsync()
    {
        if (Input is null) return;

        (bool success, string? error) = await AccountService.RegisterAsync(Input!.Email, Input!.DisplayName, Input!.Password);
        if (!success)
        {
            _errorMessage = error;
            return;
        }
        var user = await AccountService.ValidateCredentialsAsync(Input!.Email, Input!.Password);
        if (user is null)
        {
            _errorMessage = "Account created but automatic sign-in failed. Please sign in manually.";
            return;
        }

        var principal = AccountService.BuildPrincipal(user);
        await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, principal);

        Navigation.NavigateTo("/", forceLoad: true);
    }

    /// <summary>
    /// Model used to bind the registration form. Uses data annotations to provide
    /// client- and server-side validation messages.
    /// </summary>
    private sealed class RegisterInput
    {
        /// <summary>Display name shown in the UI and stored on the user profile.</summary>
        [Required(ErrorMessage = "Display name is required.")]
        public string DisplayName { get; set; } = "";

        /// <summary>User email address used as the account login.</summary>
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        /// <summary>Plain-text password entered by the user. Minimum length validated.</summary>
        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = "";

        /// <summary>Confirm password field. Must match "Password" field.</summary>
        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}