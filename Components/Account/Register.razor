@page "/register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using BudgetAndExpenseTracker.Services
@inject IAccountService AccountService
@inject NavigationManager Navigation

@*
    Registration page. Statically rendered for the same reason as Login:
    we create the account and immediately sign the user in (writing the auth
    cookie) before the response is sent.
*@

<PageTitle>Create account</PageTitle>

<section class="auth-page">
    <div class="auth-card">
        <header class="auth-card__header">
            <h1 class="auth-card__title">Create your account</h1>
            <p class="auth-card__subtitle">Start tracking your budget in minutes.</p>
        </header>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="auth-alert" role="alert">@_errorMessage</div>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="RegisterAsync" FormName="register" novalidate>
            <DataAnnotationsValidator />

            <div class="auth-field">
                <label for="name" class="auth-label">Display name</label>
                <InputText id="name" class="auth-input" @bind-Value="Input.DisplayName"
                           autocomplete="name" placeholder="Jane Doe" />
                <ValidationMessage For="() => Input.DisplayName" class="auth-validation" />
            </div>

            <div class="auth-field">
                <label for="email" class="auth-label">Email</label>
                <InputText id="email" class="auth-input" @bind-Value="Input.Email"
                           autocomplete="username" aria-required="true" placeholder="you@example.com" />
                <ValidationMessage For="() => Input.Email" class="auth-validation" />
            </div>

            <div class="auth-field">
                <label for="password" class="auth-label">Password</label>
                <InputText id="password" type="password" class="auth-input" @bind-Value="Input.Password"
                           autocomplete="new-password" aria-required="true" placeholder="At least 6 characters" />
                <ValidationMessage For="() => Input.Password" class="auth-validation" />
            </div>

            <div class="auth-field">
                <label for="confirm" class="auth-label">Confirm password</label>
                <InputText id="confirm" type="password" class="auth-input" @bind-Value="Input.ConfirmPassword"
                           autocomplete="new-password" aria-required="true" placeholder="Re-enter your password" />
                <ValidationMessage For="() => Input.ConfirmPassword" class="auth-validation" />
            </div>

            <button type="submit" class="auth-button">Create account</button>
        </EditForm>

        <p class="auth-switch">
            Already have an account? <a href="login">Log in</a>
        </p>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private RegisterInput Input { get; set; } = new();

    private string? _errorMessage;

    private async Task RegisterAsync()
    {
        var (success, error) = AccountService.Register(Input.Email, Input.DisplayName, Input.Password);
        if (!success)
        {
            _errorMessage = error;
            return;
        }

        // Auto sign-in the brand-new user, then send them to the home page.
        var user = AccountService.ValidateCredentials(Input.Email, Input.Password)!;
        var principal = AccountService.BuildPrincipal(user);
        await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, principal);

        Navigation.NavigateTo("/", forceLoad: true);
    }

    /// <summary>Form model with validation rules for registration.</summary>
    private sealed class RegisterInput
    {
        [Required(ErrorMessage = "Display name is required.")]
        public string DisplayName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
