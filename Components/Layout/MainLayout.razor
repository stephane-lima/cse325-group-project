@inherits LayoutComponentBase
@inject NavigationManager Nav

@*
    FIX #3 (RESPONSIVENESS): The previous layout hard-coded a 260px sidebar in a
    flex row with no media queries, so on phones the sidebar consumed a third of
    the screen and squished all page content. Below 768px the sidebar now
    collapses behind a hamburger button in a sticky top bar.

    The toggle is a pure-CSS checkbox hack (no @onclick) so it works on BOTH
    static SSR pages (Login/Register) and InteractiveServer pages.
*@

<div class="page">

    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" />

    @* MOBILE TOP BAR (hidden on desktop) *@
    <header class="mobile-topbar">
        <label for="nav-toggle" class="nav-toggle-btn" aria-label="Toggle navigation">&#9776;</label>
        <span class="fw-bold" style="color:#065f46;">💰 Budget Tracker</span>
    </header>

    @* SIDENAV BAR *@
    <div class="sidebar d-flex flex-column p-3">
        <nav class="nav flex-column gap-2 flex-grow-1 mt-3">
            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded fw-bold text-success bg-success bg-opacity-10 border border-success border-opacity-10 shadow-sm" href="/">
                📋 <span style="font-size: 0.95rem;">Dashboard</span>
            </a>
            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded fw-semibold text-secondary" style="transition: all 0.2s;" href="/transactions">
                💳 <span style="font-size: 0.95rem;">Transactions</span>
            </a>
            <a class="nav-link d-flex align-items-center gap-3 px-3 py-2 rounded fw-semibold text-secondary" style="transition: all 0.2s;" href="/goals">
                🎯 <span style="font-size: 0.95rem;">Financial Goals</span>
            </a>
        </nav>
    </div>

    @* MAIN PANELS *@
    <main class="main-panel flex-grow-1 d-flex flex-column">
        @* TOP UTILITY HEADER *@
        <div class="topbar d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom" style="border-color: #e2e8f0 !important;">
            <div class="d-flex align-items-center gap-2 min-w-0">
                <span class="badge bg-success px-2 py-1 text-uppercase tracking-wider font-monospace" style="font-size: 0.65rem;">LIVE</span>
                <small class="text-muted fw-medium topbar-tagline" style="font-size: 0.8rem;">Monitoring spending and dynamic balances</small>
            </div>

            @* DYNAMIC ACCOUNT CONTROL IN TOP RIGHT *@
            <div class="d-flex align-items-center gap-3 flex-shrink-0">
                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center gap-2 bg-white px-3 py-1 rounded shadow-sm border border-success border-opacity-25">
                            <span class="fw-semibold text-dark me-2 user-name" style="font-size: 0.9rem;">👤 @context.User.Identity?.Name</span>
                            <form action="Account/Logout" method="post" class="m-0 p-0 d-inline">
                                <AntiforgeryToken />
                                <button type="submit" class="btn btn-sm btn-danger px-2 fw-bold" style="font-size: 0.75rem; border-radius: 4px;">
                                    Sign Out
                                </button>
                            </form>
                        </div>
                    </Authorized>
                </AuthorizeView>
                <span class="text-muted ms-2" style="cursor: pointer;" title="Notifications">🔔</span>
            </div>
        </div>

        <article class="content flex-grow-1">
            @Body
        </article>
    </main>
</div>

<style>
    .page {
        background-color: #f4f7f6;
        min-height: 100vh;
        display: flex;
    }

    .sidebar {
        background-color: #e8f5e9;
        width: 260px;
        flex-shrink: 0;
        min-height: 100vh;
        border-right: 1px solid #d4ede1;
    }

    .main-panel {
        padding: 1.5rem;
        overflow-x: hidden;
        min-width: 0; /* critical: lets flex child shrink instead of overflowing */
    }

    .nav-link.text-secondary:hover {
        background-color: rgba(25, 135, 84, 0.05) !important;
        color: #14532d !important;
    }

    .mobile-topbar,
    .nav-toggle-input {
        display: none;
    }

    /* ===== TABLET / MOBILE ===== */
    @@media (max-width: 768px) {
        .page {
            flex-direction: column;
        }

        .mobile-topbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            background-color: #e8f5e9;
            border-bottom: 1px solid #d4ede1;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-toggle-btn {
            font-size: 1.4rem;
            cursor: pointer;
            line-height: 1;
            margin: 0;
            color: #065f46;
        }

        /* Sidebar collapsed by default on small screens */
        .sidebar {
            display: none !important;
            width: 100%;
            min-height: auto;
            border-right: none;
            border-bottom: 1px solid #d4ede1;
        }

        /* Checkbox hack: tapping the hamburger reveals the nav */
        .nav-toggle-input:checked ~ .sidebar {
            display: flex !important;
        }

        .main-panel {
            padding: 1rem;
        }

        .topbar {
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .topbar-tagline {
            display: none; /* tagline is noise on small screens */
        }
    }

    @@media (max-width: 480px) {
        .user-name {
            max-width: 110px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    }
</style>
