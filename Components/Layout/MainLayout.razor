@inherits LayoutComponentBase

<div class="app-shell">
    @* This calls your NavMenu component file directly *@
    <NavMenu />

    <main class="main-workspace">
        @* Top Runtime Header block with user initials *@
        <header class="workspace-header">
            <div class="header-left">
                <span class="badge-live">LIVE</span>
                <span class="header-subtitle">Monitoring spending</span>
            </div>
            <div class="header-profile-section">
                <button class="icon-notification-btn">
                    🔔<span class="notification-indicator"></span>
                </button>
                <div class="profile-divider"></div>
                <div class="profile-badge">SS</div>
                <span class="profile-name">Stephanie S.</span>
            </div>
        </header>

        @* Dynamic Page Content Canvas injection site *@
        <div class="content-body">
            @Body
        </div>
    </main>
</div>