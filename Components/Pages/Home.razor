@attribute [Authorize]
@page "/"
@layout Layout.MainLayout
@rendermode InteractiveServer

@using BudgetAndExpenseTracker.Models
@using BudgetAndExpenseTracker.Data
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Dashboard - Budget & Expense Tracker</PageTitle>

@* FIX #5: chart.js <script> tag removed from here — moved to App.razor.
   Script tags inside interactive components do not run on client-side
   navigation, which made the dashboard charts render blank. *@


<div class="dashboard-container container mt-4 mb-5">
    <div class="row mb-4">
        <div class="col-12 text-center text-md-start d-md-flex align-items-center justify-content-between p-4 bg-white rounded shadow-sm border-start border-primary border-4">
            <div>
                <h1 class="fw-extrabold text-dark tracking-tight mb-1" style="font-size: 2.2rem;">📊 Budget & Expense Tracker</h1>
                <p class="text-muted mb-0">Live monitoring systems active • Real-time SQLite financial analytics ledger</p>
            </div>
            <div class="mt-3 mt-md-0">
                <a href="/transactions" class="btn btn-primary px-4 py-2 shadow-sm fw-bold">
                    ➕ Manage Transactions
                </a>
            </div>
        </div>
    </div>

    <section class="row text-center mb-4">
        <div class="col-md-4 mb-3">
            <div class="card h-100 border-0 shadow-sm bg-white border-bottom border-primary border-4 rounded-top">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">👛 Total Net Balance</span>
                    <h2 class="display-6 fw-bold text-primary my-3">$@TotalBalance.ToString("N2")</h2>
                    <small class="text-muted">Combined database account assets</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body p-4 d-flex flex-column justify-content-between border-bottom border-success border-4 rounded-top">
                    <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">💵 Total Incomes</span>
                    <h2 class="display-6 fw-bold text-success my-3">+$@TotalIncome.ToString("N2")</h2>
                    <small class="text-muted">All ledger revenue records</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 border-0 shadow-sm bg-white">
                <div class="card-body p-4 d-flex flex-column justify-content-between border-bottom border-danger border-4 rounded-top">
                    <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">🧾 Total Expenses</span>
                    <h2 class="display-6 fw-bold text-danger my-3">-$@TotalExpenses.ToString("N2")</h2>
                    <small class="text-muted">All ledger debit streams</small>
                </div>
            </div>
        </div>
    </section>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="card border-0 shadow-sm p-4 h-100 bg-white rounded-3">
                <h4 class="fw-bold text-dark mb-3" style="font-size: 1.2rem;">📊 Income vs Expenses Cash Flow</h4>
                <div style="position: relative; height: 260px; width: 100%;">
                    <canvas id="cashFlowCanvas"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card border-0 shadow-sm p-4 h-100 bg-white rounded-3">
                <h4 class="fw-bold text-dark mb-3" style="font-size: 1.2rem;">📈 Net Savings Accumulation Profile</h4>
                <div style="position: relative; height: 260px; width: 100%;">
                    <canvas id="savingsTimelineCanvas"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4 rounded-3">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h3 class="fw-bold m-0" style="font-size: 1.4rem;">🕒 Recent Ledger Activity</h3>
                    <span class="badge bg-light text-dark p-2 border">Showing latest 5 entries</span>
                </div>

                @if (RecentTransactions.Count == 0)
                {
                    <div class="text-center p-5 bg-light rounded border border-dashed">
                        <p class="text-muted mb-0">No transaction records found in your tracking cluster storage file.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-uppercase fs-7 tracking-wider">
                                <tr>
                                    <th class="ps-3">Transaction Label</th>
                                    <th>Category</th>
                                    <th>Classification</th>
                                    <th>Amount</th>
                                    <th>Date Logged</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tx in RecentTransactions)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold text-dark">@tx.Title</div>
                                            <small class="text-muted fs-7">ID Reference: #@tx.Id</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-secondary border px-2 py-1 fw-semibold">@tx.Category</span>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill px-3 py-1 fw-bold @(tx.Type.ToLower() == "income" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                                @tx.Type.ToUpper()
                                            </span>
                                        </td>
                                        <td class="@(tx.Type.ToLower() == "income" ? "text-success" : "text-danger") fw-bold">
                                            @(tx.Type.ToLower() == "income" ? "+" : "-")$@tx.NumericAmount.ToString("N2")
                                        </td>
                                        <td class="text-muted">@tx.Date</td>
                                        <td class="text-end pe-3">
                                            <button type="button" class="btn btn-sm btn-link text-danger p-0 border-0" @onclick="() => DeleteTransactionAsync(tx.Id)" title="Delete Entry">
                                                🗑️ Remove
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Transaction> RecentTransactions = new();
    private decimal TotalBalance;
    private decimal TotalIncome;
    private decimal TotalExpenses;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User
            .FindFirst(ClaimTypes.NameIdentifier)?
            .Value;
        
        await RefreshDashboardDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await RenderChartsViaEvalAsync();
    }

    private async Task RefreshDashboardDataAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var all = await context.Transactions.Where(t => t.UserId == userId).ToListAsync();

        TotalIncome = all.Where(t => t.Type.ToLower() == "income").Sum(t => t.NumericAmount);
        TotalExpenses = all.Where(t => t.Type.ToLower() == "expense").Sum(t => t.NumericAmount);
        TotalBalance = 0.00m + TotalIncome - TotalExpenses;

        RecentTransactions = all
            .OrderByDescending(t => t.Date)
            .Take(5)
            .ToList();
    }

    private async Task RenderChartsViaEvalAsync()
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var chronologicalTransactions = await context.Transactions
                .Where(t => t.UserId == userId)
                .OrderBy(t => t.Date)
                .ToListAsync();

            var savingsLabels = new List<string> { "Start" };
            var savingsData = new List<decimal> { 0.00m };
            decimal runningCumulativeSavings = 0.00m;

            foreach (var tx in chronologicalTransactions)
            {
                if (tx.Type.ToLower() == "income")
                    runningCumulativeSavings += tx.NumericAmount;
                else if (tx.Type.ToLower() == "expense")
                    runningCumulativeSavings -= tx.NumericAmount;

                savingsLabels.Add(tx.Date);
                savingsData.Add(runningCumulativeSavings);
            }

            var labelsJson = System.Text.Json.JsonSerializer.Serialize(savingsLabels);
            var dataJson = System.Text.Json.JsonSerializer.Serialize(savingsData);

            var jsCode = $@"
                (function() {{
                    if (typeof Chart === 'undefined') return;

                    if (window.myCashFlowChart instanceof Chart) window.myCashFlowChart.destroy();
                    if (window.mySavingsChart instanceof Chart) window.mySavingsChart.destroy();

                    var ctx1 = document.getElementById('cashFlowCanvas');
                    if (ctx1) {{
                        window.myCashFlowChart = new Chart(ctx1, {{
                            type: 'bar',
                            data: {{
                                labels: ['Incomes', 'Expenses'],
                                datasets: [{{
                                    label: 'Total Valuation ($)',
                                    data: [{TotalIncome}, {TotalExpenses}],
                                    backgroundColor: ['#10b981', '#ef4444'],
                                    borderRadius: 6
                                }}]
                            }},
                            options: {{
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {{ legend: {{ display: false }} }}
                            }}
                        }});
                    }}

                    var ctx2 = document.getElementById('savingsTimelineCanvas');
                    if (ctx2) {{
                        window.mySavingsChart = new Chart(ctx2, {{
                            type: 'line',
                            data: {{
                                labels: {labelsJson},
                                datasets: [{{
                                    label: 'Savings Balance Accumulation ($)',
                                    data: {dataJson},
                                    borderColor: '#3b82f6',
                                    backgroundColor: 'rgba(59, 130, 246, 0.08)',
                                    fill: true,
                                    tension: 0.15,
                                    borderWidth: 3
                                }}]
                            }},
                            options: {{
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {{ y: {{ beginAtZero: true }} }}
                            }}
                        }});
                    }}
                }})();
            ";

            await JS.InvokeVoidAsync("eval", jsCode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CHART ENGINE ERROR] Failed execution runtime sequence: {ex.Message}");
        }
    }

    private async Task DeleteTransactionAsync(int id)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var item = await context.Transactions.FindAsync(id);
        if (item != null)
        {
            context.Transactions.Remove(item);
            await context.SaveChangesAsync();
            await RefreshDashboardDataAsync();
            StateHasChanged();
        }
    }
}

