@page "/transactions"
@layout Layout.MainLayout
@rendermode InteractiveServer

@using BudgetAndExpenseTracker.Models
@using BudgetAndExpenseTracker.Data
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Manage Transactions</PageTitle>

<div class="container mt-4">
    <div class="row">
        
        @* Column 1: Quick Add Transaction Entry Form *@
        <div class="col-md-5 mb-4">
            <div class="card p-4 shadow-sm">
                <h3 class="mb-3">Quick Add Transaction</h3>

                <form @onsubmit="SaveTransactionAsync" style="display: flex; flex-direction: column; gap: 12px;">
                    
                    <div>
                        <label class="form-label fw-bold">Transaction Label</label>
                        <input type="text" class="form-control" @bind="FormTitle" placeholder="e.g., Target Run" required />
                    </div>

                    <div>
                        <label class="form-label fw-bold">Type</label>
                        <select class="form-select" @bind="FormType">
                            <option value="expense">Expense</option>
                            <option value="income">Income</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label fw-bold">Category</label>
                        <select class="form-select" @bind="FormCategory">
                            <option value="Food / Groceries">Food / Groceries</option>
                            <option value="Rent / Renting">Rent / Renting</option>
                            <option value="Utilities / Bills">Utilities / Bills</option>
                            <option value="Transport">Transport</option>
                            <option value="Salary / Allowance">Salary / Allowance</option>
                            <option value="Other Miscellaneous">Other Miscellaneous</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label fw-bold">Amount ($)</label>
                        <input type="number" step="0.01" class="form-control" @bind="FormAmount" placeholder="0.00" required />
                    </div>

                    <div>
                        <label class="form-label fw-bold">Date</label>
                        <input type="date" class="form-control" @bind="FormDate" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-2">
                        Add Transaction Entry
                    </button>
                </form>
            </div>
        </div>

        @* Column 2: Full Ledger Overview *@
        <div class="col-md-7">
            <div class="card p-4 shadow-sm">
                <h3 class="mb-3">Transaction History</h3>

                @if (AllTransactions.Count == 0)
                {
                    <p class="text-muted">No database entries recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tx in AllTransactions)
                                {
                                    <tr>
                                        <td>
                                            <span class="fw-bold">@tx.Title</span><br />
                                            <small class="text-muted">@tx.Category | @tx.Date</small>
                                        </td>
                                        <td>
                                            <span class="badge @(tx.Type.ToLower() == "income" ? "bg-success" : "bg-danger")">
                                                @tx.Type.ToUpper()
                                            </span>
                                        </td>
                                        <td class="@(tx.Type.ToLower() == "income" ? "text-success" : "text-danger") fw-bold">
                                            @* Safe, inline fallback parsing for the UI table list *@
                                            $@(decimal.TryParse(tx.Amount, out var parsedAmt) ? parsedAmt.ToString("N2") : tx.Amount)
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTransactionAsync(tx.Id)">🗑️</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@code {
    private List<Transaction> AllTransactions = new();

    // Isolated primitives to drive the HTML form input fields cleanly
    private string FormTitle { get; set; } = string.Empty;
    private string FormType { get; set; } = "expense";
    private string FormCategory { get; set; } = "Food / Groceries";
    private decimal FormAmount { get; set; } = 0.00m;
    private DateTime FormDate { get; set; } = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadLedgerAsync();
    }

    private async Task LoadLedgerAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        AllTransactions = await context.Transactions.ToListAsync();
    }

    private async Task SaveTransactionAsync()
    {
        if (FormAmount <= 0 || string.IsNullOrWhiteSpace(FormTitle))
        {
            return;
        }

        using var context = await DbFactory.CreateDbContextAsync();

        var transactionToSave = new Transaction
        {
            Title = FormTitle,
            Type = FormType,
            Category = FormCategory,
            Amount = FormAmount.ToString("F2"),
            Date = FormDate.ToString("yyyy-MM-dd"),
            UserId = "1"
        };

        context.Transactions.Add(transactionToSave);
        await context.SaveChangesAsync();

        // Safe primitive resets
        FormTitle = string.Empty;
        FormAmount = 0.00m;
        FormDate = DateTime.Today;

        await LoadLedgerAsync();
    }

    private async Task DeleteTransactionAsync(int id)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var item = await context.Transactions.FindAsync(id);
        if (item != null)
        {
            context.Transactions.Remove(item);
            await context.SaveChangesAsync();
            await LoadLedgerAsync();
        }
    }
}