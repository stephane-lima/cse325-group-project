@*
    Transactions.razor
    Purpose: Interactive page for adding and listing transactions. Protected by [Authorize].
    Key bindings: binds `NewTransaction` model for quick-add and displays `TransactionsList`.
*@
@page "/transactions"
@attribute [Authorize]
@rendermode InteractiveServer

@using BudgetAndExpenseTracker.Models
@using BudgetAndExpenseTracker.Data
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@using Microsoft.Extensions.Logging
@inject ILogger<Transactions> Logger

<PageTitle>Manage Transactions</PageTitle>

<Alert Message="@_errorMessage" Type="error" Visible="@(!string.IsNullOrEmpty(_errorMessage))" OnClose="@(()=> _errorMessage = null)" />

<div class="container mt-2">
    <div class="row">
        @* LEFT COLUMN: FORM ENGINE *@
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-3">
                <h3 class="fw-bold mb-3 text-dark" style="font-size: 1.4rem;">Quick Add Transaction</h3>
                <EditForm Model="NewTransaction" OnValidSubmit="HandleValidSubmitAsync" FormName="AddTransactionForm">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase" for="transactionLabel">Transaction Label</label>
                        <InputText id="transactionLabel" @bind-Value="NewTransaction.Title" class="form-control" placeholder="e.g., Target Run" />
                        <ValidationMessage For="() => NewTransaction.Title" class="validation-message" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase" for="transactionType">Type</label>
                        <InputSelect id="transactionType" @bind-Value="NewTransaction.Type" class="form-select">
                            <option value="Expense">Expense</option>
                            <option value="Income">Income</option>
                        </InputSelect>
                        <ValidationMessage For="() => NewTransaction.Type" class="validation-message" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase" for="transactionCategory">Category</label>
                        <InputSelect id="transactionCategory" @bind-Value="NewTransaction.Category" class="form-select">
                            <option value="Food / Groceries">Food / Groceries</option>
                            <option value="Utilities / Bills">Utilities / Bills</option>
                            <option value="Rent / Renting">Rent / Renting</option>
                            <option value="Salary / Paycheck">Salary / Paycheck</option>
                            <option value="Other Miscellaneous">Other Miscellaneous</option>
                        </InputSelect>
                        <ValidationMessage For="() => NewTransaction.Category" class="validation-message" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase" for="transactionAmount">Amount ($)</label>
                        <InputNumber id="transactionAmount" @bind-Value="NewTransaction.NumericAmount" class="form-control" step="0.01" ParsingErrorMessage="Please enter a valid monetary amount."/>
                        <ValidationMessage For="() => NewTransaction.NumericAmount" class="validation-message" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary text-uppercase" for="transactionDate">Date</label>
                        <InputText id="transactionDate" @bind-Value="NewTransaction.Date" type="date" class="form-control" />
                        <ValidationMessage For="() => NewTransaction.Date" class="validation-message" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm" arial-label="Add Transaction">Add Transaction Entry</button>
                </EditForm>
            </div>
        </div>

        @* RIGHT COLUMN: REPAIRED HISTORY LIST *@
        <div class="col-md-7 mb-4">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-3">
                <h3 class="fw-bold mb-3 text-dark" style="font-size: 1.4rem;">Transaction History</h3>
                <div class="table-responsive" style="max-height: 520px; overflow-y: auto;">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-uppercase fs-7 small">
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (TransactionsList.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No records stored yet.</td>
                                </tr>
                            }
                            @foreach (var tx in TransactionsList)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark mb-0">@tx.Title</div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">@tx.Category | @tx.Date</small>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill px-2.5 py-1 fw-bold @(tx.Type.ToLower() == "income" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                            @tx.Type.ToUpper()
                                        </span>
                                    </td>
                                    <td class="fw-bold @(tx.Type.ToLower() == "income" ? "text-success" : "text-danger")">
                                        @(tx.Type.ToLower() == "income" ? "+" : "-")$@tx.Amount
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-outline-danger px-2 py-0.5 border" aria-label="Remove Transaction" @onclick="() => DeleteTransactionAsync(tx.Id)">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Transaction> TransactionsList = new();
    private string? userId;
    private string? _errorMessage;
    private Transaction NewTransaction = new() { Type = "Expense", Category = "Food / Groceries", Date = DateTime.Now.ToString("yyyy-MM-dd") };
    @* private string? userId; *@

    

    /// <summary>
    /// Called when the component is initialized. Acquires the current user's id
    /// from the authentication state and loads their transactions.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            userId = authState.User
                .FindFirst(ClaimTypes.NameIdentifier)?
                .Value;

            await LoadTransactionsAsync();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Failed to initialize Transactions page");
            _errorMessage = "Failed to load transactions. Please try again later.";
        }
    }

    /// <summary>
    /// Load the transactions for the current user from the database and
    /// populate <see cref="TransactionsList"/> sorted by date descending.
    /// </summary>
    private async Task LoadTransactionsAsync()
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            TransactionsList = await context.Transactions.Where(t => t.UserId == userId).OrderByDescending(t => t.Date).ToListAsync();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Failed to load transactions for user {UserId}", userId);
            _errorMessage = "Unable to retrieve transactions from storage.";
            TransactionsList = new();
        }
    }

    /// <summary>
    /// Handle form submission for adding a new transaction. Persists the new
    /// transaction to the database and reloads the transaction list.
    /// </summary>
    private async Task HandleValidSubmitAsync()
    {
        try
        {
            NewTransaction.UserId = userId!;
            using var context = await DbFactory.CreateDbContextAsync();
            context.Transactions.Add(NewTransaction);
            await context.SaveChangesAsync();

            // Reset state object
            NewTransaction = new() { Type = "Expense", Category = "Food / Groceries", Date = DateTime.Now.ToString("yyyy-MM-dd"), UserId = userId! };
            await LoadTransactionsAsync();
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Failed to add transaction for user {UserId}", userId);
            _errorMessage = "Failed to save the transaction. Please try again.";
        }
    }

    /// <summary>
    /// Delete the transaction with the specified id from the database and
    /// refresh the transaction list.
    /// </summary>
    /// <param name="id">Primary key of the transaction to remove.</param>
    private async Task DeleteTransactionAsync(int id)
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var item = await context.Transactions.FindAsync(id);
            if (item != null)
            {
                context.Transactions.Remove(item);
                await context.SaveChangesAsync();
                await LoadTransactionsAsync();
            }
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Failed to delete transaction {TransactionId} for user {UserId}", id, userId);
            _errorMessage = "Unable to remove the transaction. Please try again.";
        }
    }
}
