@page "/transactions"
@attribute [Authorize]
@rendermode InteractiveServer

@using BudgetAndExpenseTracker.Models
@using BudgetAndExpenseTracker.Data
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Manage Transactions</PageTitle>

<div class="container mt-2">
    <div class="row">
        @* LEFT COLUMN: FORM ENGINE *@
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-3">
                <h3 class="fw-bold mb-3 text-dark" style="font-size: 1.4rem;">Quick Add Transaction</h3>
                <EditForm Model="NewTransaction" OnValidSubmit="HandleValidSubmitAsync" FormName="AddTransactionForm">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase">Transaction Label</label>
                        <InputText @bind-Value="NewTransaction.Title" class="form-control" placeholder="e.g., Target Run" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase">Type</label>
                        <InputSelect @bind-Value="NewTransaction.Type" class="form-select">
                            <option value="Expense">Expense</option>
                            <option value="Income">Income</option>
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase">Category</label>
                        <InputSelect @bind-Value="NewTransaction.Category" class="form-select">
                            <option value="Food / Groceries">Food / Groceries</option>
                            <option value="Utilities / Bills">Utilities / Bills</option>
                            <option value="Rent / Renting">Rent / Renting</option>
                            <option value="Salary / Paycheck">Salary / Paycheck</option>
                            <option value="Other Miscellaneous">Other Miscellaneous</option>
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary text-uppercase">Amount ($)</label>
                        <InputNumber @bind-Value="NewTransaction.NumericAmount" class="form-control" min="0.01" step="0.01" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-secondary text-uppercase">Date</label>
                        <InputText @bind-Value="NewTransaction.Date" type="date" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">Add Transaction Entry</button>
                </EditForm>
            </div>
        </div>

        @* RIGHT COLUMN: REPAIRED HISTORY LIST *@
        <div class="col-md-7 mb-4">
            <div class="card border-0 shadow-sm p-4 bg-white rounded-3">
                <h3 class="fw-bold mb-3 text-dark" style="font-size: 1.4rem;">Transaction History</h3>
                <div class="table-responsive" style="max-height: 520px; overflow-y: auto;">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-uppercase fs-7 small">
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (TransactionsList.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No records stored yet.</td>
                                </tr>
                            }
                            @foreach (var tx in TransactionsList)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark mb-0">@tx.Title</div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">@tx.Category | @tx.Date</small>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill px-2.5 py-1 fw-bold @(tx.Type.ToLower() == "income" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                            @tx.Type.ToUpper()
                                        </span>
                                    </td>
                                    <td class="fw-bold @(tx.Type.ToLower() == "income" ? "text-success" : "text-danger")">
                                        @(tx.Type.ToLower() == "income" ? "+" : "-")$@tx.NumericAmount.ToString("N2")
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-outline-danger px-2 py-0.5 border" @onclick="() => DeleteTransactionAsync(tx.Id)">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Transaction> TransactionsList = new();
    private Transaction NewTransaction = new() { Type = "Expense", Category = "Food / Groceries", Date = DateTime.Now.ToString("yyyy-MM-dd") };

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactionsAsync();
    }

    private async Task LoadTransactionsAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        TransactionsList = await context.Transactions.OrderByDescending(t => t.Date).ToListAsync();
    }

    private async Task HandleValidSubmitAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        context.Transactions.Add(NewTransaction);
        await context.SaveChangesAsync();
        
        // Reset state object
        NewTransaction = new() { Type = "Expense", Category = "Food / Groceries", Date = DateTime.Now.ToString("yyyy-MM-dd") };
        await LoadTransactionsAsync();
    }

    private async Task DeleteTransactionAsync(int id)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var item = await context.Transactions.FindAsync(id);
        if (item != null)
        {
            context.Transactions.Remove(item);
            await context.SaveChangesAsync();
            await LoadTransactionsAsync();
        }
    }
}
