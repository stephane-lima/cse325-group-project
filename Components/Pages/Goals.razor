@*
    Goals.razor
    Purpose: Manage user's financial goals (create, add/remove saved amounts, delete).
    Notes: Uses data annotations for validation and protects the page with [Authorize].
*@
@page "/goals"
@layout Layout.MainLayout
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using BudgetAndExpenseTracker.Data
@using BudgetAndExpenseTracker.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims

@* 🔒 SECURITY GUARD: Protects this page from unauthenticated rogue requests *@
@attribute [Authorize]

@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Financial Goals</PageTitle>

@* ⚠️ SYSTEM NOTIFICATIONS PANEL: Clear, real-time user feedback responses *@
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show m-3 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>System Issue:</strong> @errorMessage
        <button type="button" class="btn-close" @onclick="ClearNotifications" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show m-3 shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Success:</strong> @successMessage
        <button type="button" class="btn-close" @onclick="ClearNotifications" aria-label="Close"></button>
    </div>
}

<section class="row text-center mb-4 p-3">
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-white border-bottom border-primary border-4 rounded-top">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">Current Goals</span>
                <h2 class="display-6 fw-bold text-primary my-3">@ActiveGoals.Count</h2>
                <small class="text-muted">All your financial goals!</small>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-white">
            <div class="card-body p-4 d-flex flex-column justify-content-between border-bottom border-success border-4 rounded-top">
                <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">Total Target</span>
                <h2 class="display-6 fw-bold text-success my-3">$@TotalTarget.ToString("N2")</h2>
                <small class="text-muted">Across all goals</small>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-white">
            <div class="card-body p-4 d-flex flex-column justify-content-between border-bottom border-danger border-4 rounded-top">
                <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">Total Saved</span>
                <h2 class="display-6 fw-bold text-danger my-3">$@TotalSaved.ToString("N2")</h2>
                <small class="text-muted">@TotalSavedPercentage% of total target</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-0 shadow-sm bg-white">
            <div class="card-body p-4 d-flex flex-column justify-content-between border-bottom border-danger border-4 rounded-top">
                <span class="fs-6 text-muted text-uppercase fw-bold tracking-wider">Total Remaining</span>
                <h2 class="display-6 fw-bold text-danger my-3">$@TotalRemaining.ToString("N2")</h2>
                <small class="text-muted">@TotalRemainingPercentage% of total target</small>
            </div>
        </div>
    </div>
</section>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card p-4 shadow-sm">
                <h3 class="mb-3">Create a New Goal</h3>

                <EditForm Model="newGoal" OnValidSubmit="AddGoal">
                    <DataAnnotationsValidator />
                    <div class="form-group">
                        <label class="form-label" for="goalName">Goal Name</label>
                        <InputText class="form-control" id="goalName" @bind-Value="newGoal.Name" />
                        <ValidationMessage For="() => newGoal.Name" class="validation-message" />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="targetAmount">Target Amount</label>
                        <InputNumber class="form-control" id="targetAmount" @bind-Value="newGoal.TargetAmount" />
                        <ValidationMessage For="() => newGoal.TargetAmount" class="validation-message" />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="savedAmount">Starting Saved Amount</label>
                        <InputNumber class="form-control" id="savedAmount" @bind-Value="newGoal.SavedAmount" />
                        <ValidationMessage For="() => newGoal.SavedAmount" class="validation-message" />
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="targetDate">Target Date</label>
                        <InputDate class="form-control" id="targetDate" @bind-Value="newGoal.TargetDate" />
                        <ValidationMessage For="() => newGoal.TargetDate" class="validation-message" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-2" aria-label="Add Goal">Add Goal</button>
                </EditForm>
            </div>

            <div class="card p-4 shadow-sm mt-4">
                <h3>Completed Goals</h3>

                @if (!CompletedGoals.Any())
                {
                    <div class="empty-text">You have no completed goals yet.</div>
                }

                <div class="goals-grid">
                    @foreach (var g in CompletedGoals)
                    {
                        <div class="goal-progress-box">
                            <div class="goal-meta">
                                <div>
                                    <div class="goal-name">@g.Name</div>
                                    <div class="goal-numbers">Target: $@g.TargetAmount.ToString("N2")</div>
                                    <div class="goal-numbers">Saved: $@g.SavedAmount.ToString("N2")</div>
                                    <div class="goal-numbers">Completed: @g.CompletedDate?.ToShortDateString()</div>
                                </div>
                                @* <div style="text-align: right;">
                                    <div class="goal-pct">Completed</div>
                                    <div class="goal-numbers">Saved $@g.SavedAmount.ToString("N2")</div>
                                </div> *@
                            </div>

                            <div class="progress-bar-container" style="margin: .75rem 0;">
                                <div class="progress-fill" style="width: @GetPercent(g)%"></div>
                            </div>
                            @* <div style="display:flex; gap:.5rem;">
                                <button class="btn-submit" @onclick="() => AddToSaved(g)">Add Funds</button>
                                <button class="btn-submit" @onclick="() => RemoveFromSaved(g)">Remove Funds</button>
                                <button class="btn-delete" @onclick="() => RemoveGoal(g)">🗑️</button>
                            </div> *@
                        </div>
                    }
                </div> 
            </div>
        </div>

        <div class="col-md-7">
            <div class="card p-4 shadow-sm">
                <h3>Current Goals</h3>

                @if (!ActiveGoals.Any())
                {
                    <div class="empty-text">You have no goals yet — add one using the form.</div>
                }

                <div class="goals-grid">
                    @foreach (var g in ActiveGoals)
                    {
                        <div class="goal-progress-box">
                            <div class="goal-meta">
                                <div>
                                    <div class="goal-name">@g.Name</div>
                                    <div class="goal-numbers">Target: $@g.TargetAmount.ToString("N2")</div>
                                    <div class="goal-numbers">Due: @g.TargetDate.ToShortDateString()</div>
                                </div>
                                <div style="text-align: right;">
                                    <div class="goal-pct">@GetPercent(g) %</div>
                                    <div class="goal-numbers">Saved: $@g.SavedAmount.ToString("N2")</div>
                                </div>
                            </div>

                            <div class="progress-bar-container" style="margin: .75rem 0;">
                                <div class="progress-fill" style="width: @GetPercent(g)%"></div>
                            </div>

                            <div class="form-group-row d-flex flex-column flex-xl-row align-items-center" style="margin-top: .5rem;">
                                <div class="w-100 mb-2 mb-xl-0">
                                    <input class="form-control" type="number" step="0.01" @bind="gEditAmounts[g.Id]" placeholder="Add amount" />
                                </div>
                                <div class="d-flex" style="gap:.5rem;">
                                    <button class="btn-submit" aria-label="Add Funds" @onclick="() => AddToSaved(g)">Add Funds</button>
                                    <button class="btn-submit" aria-label="Remove Funds" @onclick="() => RemoveFromSaved(g)">Remove Funds</button>
                                    <button class="btn-delete" aria-label="Remove Goal" @onclick="() => RemoveGoal(g)">🗑️</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Goal> goals = new();
    private Goal newGoal = new() { TargetDate = DateTime.Today.AddMonths(1) };
    private Dictionary<int, decimal> gEditAmounts = new();

    private List<Goal> ActiveGoals => goals.Where(g => !g.IsCompleted).ToList();

    private List<Goal> CompletedGoals => goals.Where(g => g.IsCompleted).ToList();

    private string? userId;

    private decimal TotalTarget;
    private decimal TotalSaved;
    private decimal TotalRemaining;
    private decimal TotalSavedPercentage;
    private decimal TotalRemainingPercentage;

    // Feedback Notification Strings
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    

    /// <summary>
    /// Component initialization lifecycle method. Acquires the current user id
    /// from the authentication state and loads the user's goals.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User
            .FindFirst(ClaimTypes.NameIdentifier)?
            .Value;

        await LoadGoalsAsync();
    }

    /// <summary>
    /// Load goals for the current user from the database and compute
    /// aggregate totals used by the UI summary cards.
    /// </summary>
    private async Task LoadGoalsAsync()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            goals = await db.Goals.Where(g => g.UserId == userId).OrderByDescending(g => g.Id).ToListAsync();
            gEditAmounts = goals.ToDictionary(g => g.Id, g => 0m);
            
            TotalTarget = goals.Where(x => x.SavedAmount < x.TargetAmount).Sum(x => x.TargetAmount);
            TotalSaved = goals.Where(x => x.SavedAmount < x.TargetAmount).Sum(x => x.SavedAmount);
            TotalRemaining = TotalTarget - TotalSaved;
            TotalSavedPercentage = (TotalTarget == 0) ? 0 : Math.Round((TotalSaved / TotalTarget) * 100, 2);
            TotalRemainingPercentage = 100 - TotalSavedPercentage;
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load financial target records from storage engine.";
            Console.WriteLine($"[LOAD GOALS FATAL]: {ex.Message}");
        }
    }

    /// <summary>
    /// Persist a new goal to the database using values from the bound
    /// <see cref="newGoal"/> model, then refresh the list and UI.
    /// </summary>
    private async Task AddGoal()
    {
        try
        {
            ClearNotifications();
            var g = new Goal
            {
                Name = newGoal.Name?.Trim() ?? "Untitled Goal",
                TargetAmount = newGoal.TargetAmount,
                SavedAmount = newGoal.SavedAmount,
                TargetDate = newGoal.TargetDate,
                UserId = userId!
            };

            using var db = await DbFactory.CreateDbContextAsync();
            db.Goals.Add(g);
            await db.SaveChangesAsync();

            successMessage = $"Successfully initiated savings roadmap target for '{g.Name}'!";
            await LoadGoalsAsync();
            newGoal = new Goal { TargetDate = DateTime.Today.AddMonths(1) };
        }
        catch (Exception ex)
        {
            errorMessage = "Database constraint violation. Target tracking objective creation aborted.";
            Console.WriteLine($"[ADD GOAL FATAL]: {ex.Message}");
        }
    }

    /// <summary>
    /// Remove the supplied goal record from persistent storage and refresh the UI.
    /// </summary>
    /// <param name="g">The goal instance to delete.</param>
    private async Task RemoveGoal(Goal g)
    {
        try
        {
            ClearNotifications();
            using var db = await DbFactory.CreateDbContextAsync();
            db.Goals.Remove(g);
            await db.SaveChangesAsync();
            
            successMessage = "Financial target parameter purged cleanly.";
            await LoadGoalsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Purge command declined. Unable to delete objective records.";
            Console.WriteLine($"[REMOVE GOAL FATAL]: {ex.Message}");
        }
    }

    /// <summary>
    /// Add funds to a goal's saved amount using the value from the edit buffer
    /// and mark the goal as completed when the target is reached.
    /// </summary>
    /// <param name="g">Goal to add funds to.</param>
    private async Task AddToSaved(Goal g)
    {
        try
        {
            ClearNotifications();
            if (!gEditAmounts.TryGetValue(g.Id, out var amt)) return;
            if (amt <= 0)
            {
                errorMessage = "Allocated amount metrics must yield positive numeric structures.";
                return;
            }

            using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.Goals.FindAsync(g.Id);
            if (entity == null) return;
            
            entity.SavedAmount += Math.Round(amt, 2);

            if (entity.SavedAmount >= entity.TargetAmount && entity.CompletedDate == null)
            {
                entity.CompletedDate = DateTime.Now;
            }

            await db.SaveChangesAsync();
            
            successMessage = $"Successfully deposited ${amt:N2} towards your objective!";
            await LoadGoalsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Balance mutation aborted due to data tier constraints.";
            Console.WriteLine($"[ADD FUNDS FATAL]: {ex.Message}");
        }
    }

    /// <summary>
    /// Subtract funds from a goal's saved amount using the value from the edit buffer.
    /// </summary>
    /// <param name="g">Goal to remove funds from.</param>
    private async Task RemoveFromSaved(Goal g)
    {
        try
        {
            ClearNotifications();
            if (!gEditAmounts.TryGetValue(g.Id, out var amt)) return;
            if (amt <= 0)
            {
                errorMessage = "Deduction request values must explicitly contain positive dimensions.";
                return;
            }

            using var db = await DbFactory.CreateDbContextAsync();
            var entity = await db.Goals.FindAsync(g.Id);
            if (entity == null) return;
            
            entity.SavedAmount -= Math.Round(amt, 2);
            await db.SaveChangesAsync();
            
            successMessage = $"Successfully deducted ${amt:N2} from fund configurations.";
            await LoadGoalsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Balance adjustments terminated due to system state conflicts.";
            Console.WriteLine($"[REMOVE FUNDS FATAL]: {ex.Message}");
        }
    }

    /// <summary>
    /// Compute a whole-number percent completion for the supplied goal (0-100).
    /// </summary>
    private int GetPercent(Goal g)
    {
        if (g.TargetAmount <= 0) return 0;
        var pct = (int)Math.Min(100, Math.Floor((double)(g.SavedAmount / g.TargetAmount * 100)));
        return pct;
    }

    /// <summary>
    /// Clear in-page notification messages displayed to the user.
    /// </summary>
    private void ClearNotifications()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}